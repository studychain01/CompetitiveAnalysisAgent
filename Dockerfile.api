# BattleScope API — build context is the **monorepo root** (Railway default).
# For a slimmer context, set service Root Directory to ``apps/api`` and use ``apps/api/Dockerfile`` instead.
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

COPY apps/api/pyproject.toml .
COPY apps/api/src ./src

RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir .

EXPOSE 8000

CMD ["sh", "-c", "exec python -m uvicorn battlescope_api.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
