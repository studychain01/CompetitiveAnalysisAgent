# =============================================================================
# BattleScope — copy to ``apps/api/.env`` (or set vars in the shell).
# ``settings.py`` loads ``apps/api/.env`` first, then repo-root ``.env`` if present.
# =============================================================================

# --- LLM (required for the full graph) ---------------------------------------
# Secret from https://platform.openai.com/api-keys (sk- or sk-proj-).
OPENAI_API_KEY=
# Host only (https://api.openai.com) or full SDK root; host-style is normalized.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# --- SEC / 10-K (Item 1A path via filing metadata + HTML download) ---------
# Financial Modeling Prep — https://site.financialmodelingprep.com/developer/docs/
# Used to resolve latest 10-K links; ``sec_risk`` then fetches filing HTML from SEC.
# Alias: FINANCIAL_MODELING_PREP_API_KEY
FMP_API_KEY=
# Identify your app to SEC EDGAR (required). Default uses ``user.invalid`` (RFC 2606 placeholder) — replace with your URL or mailto: in production.
SEC_EDGAR_USER_AGENT=BattleScope/1.0 (mailto:battlescope@user.invalid)

# --- Web research tools (optional but recommended for demos) ----------------
TAVILY_API_KEY=
# Firecrawl — https://www.firecrawl.dev/ (keys often start with fc-)
FIRECRAWL_API_KEY=
# NewsAPI.org — https://newsapi.org/register (competitor + peer ReAct nodes).
# Aliases: NEWSAPI_API_KEY, NEWS_API_API_KEY, NEWSAPI_KEY, NEWS_ORG_API_KEY
NEWSAPI_API_KEY=
# Alpha Vantage — https://www.alphavantage.co/support/#api-key (optional intake / transcript hints).
# Alias: ALPHAVANTAGE_API_KEY
ALPHA_VANTAGE_API_KEY=

# --- HTTP API (FastAPI) ------------------------------------------------------
# Browser origins allowed to call this API (comma-separated). For a deployed UI,
# include that origin, e.g. CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
HTTP_MAX_RETRIES=2
HTTP_BACKOFF_BASE_S=0.4

# --- Graph tuning (defaults match ``settings.py``) ---------------------------
INTAKE_CONTEXT_MAX_CHARS=16000
# Optional two-phase Tavily (max 2 queries) before final strategy synthesis.
STRATEGY_TAVILY_FOLLOWUP=false

# Uncomment to override defaults:
#COMPETITOR_REACT_RECURSION_LIMIT=40
#PEER_REACT_RECURSION_LIMIT=40
#COMPETITOR_CONTEXT_MAX_CHARS=180000
#STRATEGY_CONTEXT_MAX_CHARS=72000
#SEC_RISK_FILING_DOWNLOAD_MAX_CHARS=250000
#SEC_RISK_EXCERPT_MAX_CHARS=200000

# --- LangSmith / LangChain tracing (optional) -------------------------------
# Loaded into os.environ on startup so LangSmith sees them without shell export.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=battlescope
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=battlescope
