# LLM (OpenAI-compatible chat completions; used by IntakeProfiler)
OPENAI_API_KEY=
# Host only (https://api.openai.com) or full SDK root (https://api.openai.com/v1). Host-style is normalized for ChatOpenAI.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
# Optional later: ANTHROPIC_API_KEY=

# Research tools
TAVILY_API_KEY=
# Firecrawl: API key from https://www.firecrawl.dev/ (often starts with fc-). Not the same as Tavily/OpenAI.
FIRECRAWL_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key — used for EARNINGS_CALL_TRANSCRIPT (public equities).
ALPHA_VANTAGE_API_KEY=
# OpenAI: secret key from https://platform.openai.com/api-keys (starts with sk- or sk-proj-). Not your LangSmith key.

# API
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
HTTP_MAX_RETRIES=2
HTTP_BACKOFF_BASE_S=0.4

# Intake
INTAKE_CONTEXT_MAX_CHARS=12000

# LangSmith — loaded into os.environ on startup (see settings.py load_dotenv).
# Official quickstart-style:
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=battlescope
# LangChain-compatible names (also read by langsmith):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=battlescope
