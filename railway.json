{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": ["apps/api/**", "Dockerfile.api", "railway.json"]
  },
  "deploy": {
    "startCommand": "/docker-entrypoint.sh",
    "healthcheckPath": "/health"
  }
}
