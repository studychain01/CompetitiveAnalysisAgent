{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": ["apps/api/**", "Dockerfile.api", "railway.json"]
  },
  "deploy": {
    "startCommand": "python -m uvicorn battlescope_api.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health"
  }
}
